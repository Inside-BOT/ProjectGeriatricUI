<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Assistant Configuration Panel</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=300;400;500;600;700;800&display=swap');
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        .theme-transition {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        /* Custom scrollbars */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(156, 163, 175, 0.5);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(156, 163, 175, 0.7);
        }
    </style>
</head>
<body class="bg-[#E8F1F8] text-gray-800 min-h-screen flex items-center justify-center p-2 sm:p-4">

    <!-- Main Container (Shortened height with soft light-grey background) -->
    <div id="app-card" class="w-full max-w-lg bg-[#E9ECEF] rounded-3xl shadow-2xl border-4 border-[#1E3A5F] overflow-hidden theme-transition flex flex-col h-[620px] relative">
        
        <!-- HEADER -->
        <header id="app-header" class="bg-[#2D6CDF] text-white py-4 px-6 flex items-center justify-between border-b-2 border-[#1E3A5F] shrink-0">
            <div class="flex items-center gap-3">
                <button id="header-back-btn" class="p-1.5 hover:bg-white/20 rounded-lg transition hidden" onclick="navigateBack()">
                    <i data-lucide="chevron-left" class="w-6 h-6"></i>
                </button>
                <h1 id="header-title" class="text-2xl font-extrabold tracking-tight">Settings</h1>
            </div>
            <!-- Clickable theme pill cycles modes directly -->
            <button id="theme-pill" class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider transition active:scale-95 duration-200" onclick="cycleThemeMode()">
                <i data-lucide="sun" id="theme-icon" class="w-3.5 h-3.5"></i>
                <span id="theme-label">Light Mode</span>
            </button>
        </header>

        <!-- APP SCREENS CONTAINER -->
        <main class="flex-1 overflow-y-auto p-5 relative flex flex-col justify-between">
            
            <!-- Dynamic Content Area -->
            <div id="content-area" class="w-full flex-1">
                <!-- Screens will render dynamically here -->
            </div>

            <!-- MODAL OVERLAY FOR EVENTS TABLE -->
            <div id="calendar-modal" class="absolute inset-0 bg-black/60 backdrop-blur-sm z-30 hidden items-center justify-center p-4">
                <div id="modal-box" class="bg-[#E9ECEF] dark:bg-zinc-900 text-gray-900 dark:text-gray-100 rounded-2xl p-5 border-2 border-[#2D6CDF] w-full max-w-sm shadow-2xl transform scale-95 opacity-0 transition-all duration-200 max-h-[90%] flex flex-col">
                    <div class="flex justify-between items-center mb-3 pb-2 border-b border-gray-200 dark:border-zinc-800 shrink-0">
                        <div>
                            <h3 class="font-bold text-lg text-[#1E3A5F] dark:text-[#00E5FF]" id="modal-title">Selected Date</h3>
                            <p class="text-[10px] text-gray-400 font-semibold uppercase tracking-wider" id="modal-subtitle">Schedule Manager</p>
                        </div>
                        <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 p-1 rounded-lg hover:bg-gray-100 dark:hover:bg-zinc-800">
                            <i data-lucide="x" class="w-5 h-5"></i>
                        </button>
                    </div>

                    <!-- Events List Container -->
                    <div class="flex-1 overflow-y-auto mb-4 min-h-[120px]" id="modal-events-list">
                        <!-- Rendered list/table of events -->
                    </div>

                    <!-- New Event Form -->
                    <div class="border-t border-gray-200 dark:border-zinc-800 pt-3 shrink-0">
                        <p class="text-xs font-bold text-[#1E3A5F] dark:text-[#00E5FF] mb-2 uppercase tracking-wide font-sans tracking-wide">Add New Event</p>
                        <form id="new-event-form" onsubmit="handleFormSubmit(event)" class="space-y-2">
                            <div class="grid grid-cols-3 gap-2">
                                <input type="time" id="event-time" required class="col-span-1 p-2 text-xs border border-[#1E3A5F] dark:border-[#00E5FF] bg-[#E9ECEF] dark:bg-zinc-800 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-1 focus:ring-[#2D6CDF]">
                                <input type="text" id="event-message" placeholder="Message/Reminders..." required class="col-span-2 p-2 text-xs border border-[#1E3A5F] dark:border-[#00E5FF] bg-[#E9ECEF] dark:bg-zinc-800 text-gray-900 dark:text-white rounded-lg focus:outline-none focus:ring-1 focus:ring-[#2D6CDF]">
                            </div>
                            <button type="submit" class="w-full bg-[#2D6CDF] hover:bg-[#1E3A5F] text-white py-2 rounded-lg text-xs font-bold transition active:scale-95 flex items-center justify-center gap-1">
                                <i data-lucide="plus" class="w-3.5 h-3.5"></i> Add to Schedule
                            </button>
                        </form>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <!-- Notification Toast -->
    <div id="toast" class="fixed bottom-5 left-1/2 transform -translate-x-1/2 bg-gray-900 text-white px-5 py-3 rounded-2xl shadow-xl flex items-center gap-2 text-sm font-semibold opacity-0 translate-y-4 pointer-events-none transition-all duration-300 z-50">
        <i data-lucide="check-circle" class="w-4 h-4 text-emerald-400"></i>
        <span id="toast-msg">Settings saved successfully</span>
    </div>

    <script>
        // --- Core State Storage (Starts empty for contacts) ---
        let appData = {
            personality: 'You are a friendly, helpful and caring assistant who is aimed to help an elderly person with possible loneliness with short informative replies designed to be spoken with no involvement in physical tasks. Answers in British English with metric units.',
            voice: 'RltfKVMDaAfhpmJT415L',
            words: {
                start: 'Google',
                end: 'bye'
            },
            contacts: [], // No pre-saved contacts when starting
            mode: 'Light', // 'Light', 'Dark', 'Automatic'
            events: {}, // Single dates lookup: { "YYYY-MM-DD": [ { time: "10:00", message: "Take medicine" }, ... ] }
            dailyEvents: [], // Daily repeats: [ { time: "08:00", message: "Breakfast chime" } ]
            weeklyEvents: {}, // Weekly repeats: { "Mon": [ { time: "09:00", message: "Water plants" } ] }
            monthlyEvents: {}, // Monthly repeats: { "1": [ { time: "12:00", message: "Rent Due" } ] }
            yearlyEvents: {} // Yearly repeats: { "MM-DD": [ { time: "12:00", message: "Birthday celebration" } ] }
        };

        // Current navigation track
        let currentPath = ['root'];

        // Calendar constants
        const months = [
            { name: "January", days: 31 },
            { name: "February", days: 28 },
            { name: "March", days: 31 },
            { name: "April", days: 30 },
            { name: "May", days: 31 },
            { name: "June", days: 30 },
            { name: "July", days: 31 },
            { name: "August", days: 31 },
            { name: "September", days: 30 },
            { name: "October", days: 31 },
            { name: "November", days: 30 },
            { name: "December", days: 31 }
        ];
        const daysOfWeek = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
        
        let currentYear = new Date().getFullYear();
        let currentMonth = new Date().getMonth();
        let showingMonthDropdown = false;
        let showingYearDropdown = false;

        // Track what kind of date we are looking at in the event modal
        let activeModalScope = {
            type: '', // 'single', 'daily', 'weekly', 'monthly', 'yearly'
            key: ''   // Specific key for storing data in appData arrays
        };

        // --- Theme Definitions (Pure White `#FFFFFF` swapped to very light slate-grey `#E9ECEF`) ---
        const themes = {
            light: {
                bg: '#E8F1F8',
                cardBg: '#E9ECEF', // Beautiful, distinct soft grey within blue borders
                primary: '#2D6CDF',
                text: '#1A1A1A',
                border: '#1E3A5F',
                secondaryText: '#4A5568',
                inputBg: '#DFE2E6'
            },
            dark: {
                bg: '#121212',
                cardBg: '#1E1E1E',
                primary: '#00E5FF',
                text: '#FFFFFF',
                border: '#00E5FF',
                secondaryText: '#A0AEC0',
                inputBg: '#2D2D2D'
            }
        };

        // --- App Setup ---
        window.addEventListener('DOMContentLoaded', () => {
            loadLocalData();
            applyTheme();
            renderScreen();
        });

        // --- Local Storage Management ---
        function loadLocalData() {
            const saved = localStorage.getItem('ai_assistant_settings_v5');
            if (saved) {
                try {
                    appData = { ...appData, ...JSON.parse(saved) };
                } catch(e) {
                    console.error("Could not parse saved configurations, using default.");
                }
            }
        }

        function saveLocalData() {
            localStorage.setItem('ai_assistant_settings_v5', JSON.stringify(appData));
        }

        // --- Toast Alerts ---
        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-msg').textContent = message;
            toast.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
            toast.classList.add('opacity-100', 'translate-y-0');
            setTimeout(() => {
                toast.classList.remove('opacity-100', 'translate-y-0');
                toast.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
            }, 2500);
        }

        // --- Theme Management ---
        function cycleThemeMode() {
            const currentMode = appData.mode;
            let nextMode = 'Light';
            if (currentMode === 'Light') nextMode = 'Dark';
            else if (currentMode === 'Dark') nextMode = 'Automatic';
            
            appData.mode = nextMode;
            saveLocalData();
            applyTheme();
            showToast(`${nextMode} display mode active`);
        }

        function getActiveTheme() {
            if (appData.mode === 'Light') return 'light';
            if (appData.mode === 'Dark') return 'dark';
            const hours = new Date().getHours();
            return (hours >= 20 || hours < 7) ? 'dark' : 'light';
        }

        function applyTheme() {
            const mode = getActiveTheme();
            const active = themes[mode];
            
            // Toggle the 'dark' class on the document and body element so Tailwind's dark: modifiers work!
            document.documentElement.classList.toggle('dark', mode === 'dark');
            document.body.classList.toggle('dark', mode === 'dark');
            
            document.body.style.backgroundColor = active.bg;
            
            const card = document.getElementById('app-card');
            card.style.backgroundColor = active.cardBg;
            card.style.borderColor = active.border;
            card.style.color = active.text;

            const header = document.getElementById('app-header');
            header.style.backgroundColor = active.primary;
            header.style.borderColor = active.border;

            const themeLabel = document.getElementById('theme-label');
            const themeIcon = document.getElementById('theme-icon');
            const themePill = document.getElementById('theme-pill');
            
            themeLabel.textContent = `${appData.mode} Mode`;

            if (appData.mode === 'Light') {
                themeIcon.setAttribute('data-lucide', 'sun');
            } else if (appData.mode === 'Dark') {
                themeIcon.setAttribute('data-lucide', 'moon');
            } else {
                themeIcon.setAttribute('data-lucide', 'clock');
            }
            
            // distinctive bubble styling for Dark Mode
            if (mode === 'dark') {
                header.classList.remove('text-white');
                header.classList.add('text-black');
                themePill.className = "flex items-center gap-2 bg-zinc-950 text-[#00E5FF] border-2 border-[#00E5FF] px-4 py-2 rounded-full text-xs font-extrabold uppercase tracking-widest shadow-[0_0_15px_rgba(0,229,255,0.6)] transition active:scale-95 duration-200";
            } else {
                header.classList.add('text-white');
                header.classList.remove('text-black');
                themePill.className = "flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white border border-white/20 px-3 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider transition active:scale-95 duration-200";
            }

            document.querySelectorAll('.btn-themed-primary').forEach(el => {
                el.style.backgroundColor = active.primary;
                el.style.color = mode === 'dark' ? '#000000' : '#FFFFFF';
            });
            document.querySelectorAll('.themed-text-secondary').forEach(el => {
                el.style.color = active.secondaryText;
            });
            document.querySelectorAll('.themed-border').forEach(el => {
                el.style.borderColor = active.border;
            });
            document.querySelectorAll('.themed-input').forEach(el => {
                el.style.backgroundColor = active.inputBg;
                el.style.color = active.text;
                el.style.borderColor = active.border;
            });

            lucide.createIcons();
        }

        // --- Screen Router ---
        function renderScreen() {
            const current = currentPath[currentPath.length - 1];
            const content = document.getElementById('content-area');
            const backBtn = document.getElementById('header-back-btn');
            const titleEl = document.getElementById('header-title');

            if (currentPath.length > 1) {
                backBtn.classList.remove('hidden');
            } else {
                backBtn.classList.add('hidden');
            }

            content.innerHTML = '';

            switch (current) {
                case 'root':
                    titleEl.textContent = "Settings";
                    content.innerHTML = renderMenu([
                        { id: 'ai', label: '➔ AI Config', desc: 'Personality & Voice parameters' },
                        { id: 'contacts', label: '➔ Contacts', desc: 'Configure contacts' },
                        { id: 'calendar', label: '➔ Calendar', desc: 'Configure schedule & reminders' }
                    ]);
                    break;

                case 'ai':
                    titleEl.textContent = "AI Settings";
                    content.innerHTML = renderMenu([
                        { id: 'personality', label: '➔ Personality', desc: 'Configure agent behaviour' },
                        { id: 'voice', label: '➔ Voice', desc: 'ElevenLabs custom key configuration' },
                        { id: 'words', label: '➔ Activation Keywords', desc: 'Set wake & termination words' }
                    ]);
                    break;

                case 'calendar':
                    titleEl.textContent = "Calendar Setup";
                    content.innerHTML = renderMenu([
                        { id: 'single_time', label: '➔ Single Event', desc: 'Plan single-time reminders' },
                        { id: 'repeated', label: '➔ Repeated Events', desc: 'Configure recurrence schedules' }
                    ]);
                    break;

                case 'repeated':
                    titleEl.textContent = "Repeated";
                    content.innerHTML = renderMenu([
                        { id: 'daily', label: '➔ Daily Routines', desc: 'Set up everyday reminder schedules' },
                        { id: 'weekly', label: '➔ Weekly Events', desc: 'Define active weekday schedules' },
                        { id: 'monthly', label: '➔ Monthly Events', desc: 'Configure day-of-the-month recurrences' },
                        { id: 'yearly', label: '➔ Yearly Reminders', desc: 'Schedule yearly recurring dates' }
                    ]);
                    break;

                case 'contacts':
                    titleEl.textContent = "Contacts";
                    renderContactsScreen(content);
                    break;

                case 'add_contact':
                    titleEl.textContent = "Add Contact";
                    renderAddContactScreen(content);
                    break;

                case 'personality':
                    titleEl.textContent = "Personality";
                    renderPersonalityScreen(content);
                    break;

                case 'voice':
                    titleEl.textContent = "Voice Key";
                    renderVoiceScreen(content);
                    break;

                case 'words':
                    titleEl.textContent = "Activation Words";
                    renderWordsScreen(content);
                    break;

                case 'daily':
                    titleEl.textContent = "Daily Events";
                    renderDailyScreen(content);
                    break;

                case 'weekly':
                    titleEl.textContent = "Weekly Events";
                    renderWeeklyScreen(content);
                    break;

                case 'monthly':
                    titleEl.textContent = "Monthly Events";
                    renderMonthlyScreen(content);
                    break;

                case 'single_time':
                case 'yearly':
                    titleEl.textContent = current === 'yearly' ? "Yearly Repeats" : "Single Time";
                    renderCalendarScreen(content, current);
                    break;
            }

            applyTheme();
            lucide.createIcons();
        }

        // --- Component Renderers ---
        function renderMenu(items) {
            let listHTML = '<div class="space-y-4 pt-2 animate-fade-in">';
            items.forEach(item => {
                listHTML += `
                    <button onclick="navigate('${item.id}')" class="w-full text-left p-4 rounded-2xl border-2 themed-border hover:scale-[1.01] hover:shadow-md active:scale-95 transition-all flex justify-between items-center bg-transparent group">
                        <div class="pr-2">
                            <!-- Hover color updated to exact dark blue shade (#1E3A5F) for Light Mode -->
                            <span class="font-bold text-lg md:text-xl block group-hover:text-[#1E3A5F] dark:group-hover:text-[#0085FF] transition">${item.label}</span>
                            <span class="text-xs themed-text-secondary mt-0.5 block">${item.desc}</span>
                        </div>
                        <i data-lucide="chevron-right" class="w-5 h-5 shrink-0 opacity-60 group-hover:opacity-100 group-hover:translate-x-1 transition"></i>
                    </button>
                `;
            });
            listHTML += '</div>';
            return listHTML;
        }

        // --- Contacts Screen ---
        function renderContactsScreen(container) {
            let listHTML = '';
            if (appData.contacts.length === 0) {
                listHTML = `
                    <div class="flex flex-col items-center justify-center py-16 text-gray-400">
                        <i data-lucide="users" class="w-12 h-12 opacity-30 mb-2"></i>
                        <p class="text-sm font-semibold">No contacts saved yet.</p>
                        <p class="text-xs">Click the '+' button above to add one.</p>
                    </div>
                `;
            } else {
                listHTML = `<div class="space-y-3 max-h-[380px] overflow-y-auto pr-1">`;
                appData.contacts.forEach((contact, idx) => {
                    listHTML += `
                        <div class="p-4 rounded-2xl border-2 themed-border flex justify-between items-center bg-gray-50/50 dark:bg-zinc-850/30">
                            <div>
                                <span class="font-bold text-base block">${contact.name}</span>
                                <span class="text-xs themed-text-secondary font-semibold block mt-1 flex items-center gap-1">
                                    <i data-lucide="phone" class="w-3 h-3"></i> ${contact.phone}
                                </span>
                            </div>
                            <button onclick="deleteContact(${idx})" class="p-2 text-rose-500 hover:text-rose-700 hover:bg-rose-50 dark:hover:bg-rose-950/30 rounded-xl transition active:scale-95">
                                <i data-lucide="trash-2" class="w-5 h-5"></i>
                            </button>
                        </div>
                    `;
                });
                listHTML += `</div>`;
            }

            container.innerHTML = `
                <div class="space-y-4 animate-fade-in">
                    <div class="flex justify-between items-center">
                        <p class="text-sm font-medium themed-text-secondary">Companion and emergency contacts:</p>
                        <button onclick="navigate('add_contact')" class="p-2.5 bg-[#2D6CDF] hover:bg-[#1E3A5F] dark:bg-zinc-800 dark:hover:bg-zinc-700 text-white rounded-xl transition active:scale-95 shadow-md flex items-center justify-center" title="Add Contact">
                            <i data-lucide="plus" class="w-5 h-5"></i>
                        </button>
                    </div>
                    ${listHTML}
                </div>
            `;
        }

        // --- Add New Contact Screen ---
        function renderAddContactScreen(container) {
            container.innerHTML = `
                <div class="space-y-6 animate-fade-in">
                    <p class="text-sm font-medium themed-text-secondary">
                        Enter details for the new contact below.
                    </p>
                    <form id="contact-form" onsubmit="saveContact(event)" class="space-y-4">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider mb-2 themed-text-secondary">Contact Name</label>
                            <input id="contact-name" type="text" required class="w-full p-4 rounded-2xl border-2 bg-[#E9ECEF] dark:bg-zinc-800 text-gray-900 dark:text-white border-gray-300 dark:border-zinc-700 focus:ring-2 focus:ring-[#2D6CDF] focus:outline-none font-bold text-lg" placeholder="e.g. Mary Jane" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider mb-2 themed-text-secondary">Telephone Number</label>
                            <input id="contact-phone" type="tel" required class="w-full p-4 rounded-2xl border-2 bg-[#E9ECEF] dark:bg-zinc-800 text-gray-900 dark:text-white border-gray-300 dark:border-zinc-700 focus:ring-2 focus:ring-[#2D6CDF] focus:outline-none font-bold text-lg" placeholder="e.g. +44 1234 567890" />
                        </div>
                        
                        <button type="submit" class="w-full py-4 rounded-2xl font-bold btn-themed-primary transition active:scale-95 shadow-md flex items-center justify-center gap-2">
                            <i data-lucide="save" class="w-5 h-5"></i> SAVE CONTACT
                        </button>
                    </form>
                </div>
            `;
        }

        function saveContact(e) {
            e.preventDefault();
            const name = document.getElementById('contact-name').value.trim();
            const phone = document.getElementById('contact-phone').value.trim();
            if (name && phone) {
                appData.contacts.push({ name, phone });
                saveLocalData();
                showToast("New contact saved successfully");
                currentPath.pop(); // Go back to contacts list view
                renderScreen();
            }
        }

        function deleteContact(idx) {
            appData.contacts.splice(idx, 1);
            saveLocalData();
            showToast("Contact deleted");
            renderScreen();
        }

        // Softened Typography and elegant layouts for Personality Screen
        function renderPersonalityScreen(container) {
            container.innerHTML = `
                <div class="space-y-4 animate-fade-in font-sans">
                    <p class="text-sm font-normal tracking-wide leading-relaxed text-gray-500 dark:text-zinc-400">
                        Design a warm and customized persona for your AI companion. Feel free to set conversational rules, preferences, or guidelines.
                    </p>
                    <textarea id="personality-input" class="w-full h-44 p-4 rounded-2xl border-2 themed-input focus:ring-2 focus:ring-[#2D6CDF] dark:focus:ring-[#00E5FF] focus:outline-none text-sm tracking-wide leading-relaxed font-normal resize-none transition duration-150" placeholder="Personality description...">${appData.personality}</textarea>
                    
                    <button onclick="savePersonality()" class="w-full py-4 rounded-2xl font-bold btn-themed-primary transition active:scale-95 shadow-md flex items-center justify-center gap-2">
                        <i data-lucide="save" class="w-5 h-5"></i> SAVE CONFIGURATION
                    </button>
                </div>
            `;
        }

        function savePersonality() {
            const input = document.getElementById('personality-input');
            if (input) {
                appData.personality = input.value;
                saveLocalData();
                showToast("AI Agent personality updated");
                setTimeout(navigateBack, 600);
            }
        }

        // Softened Typography and layouts for Voice Screen
        function renderVoiceScreen(container) {
            container.innerHTML = `
                <div class="space-y-4 animate-fade-in font-sans">
                    <p class="text-sm font-normal tracking-wide leading-relaxed text-gray-500 dark:text-zinc-400">
                        Adjust speech properties using ElevenLabs keys. Paste your generated key below to modify speaker tones.
                    </p>
                    <div class="relative">
                        <input id="voice-input" type="text" class="w-full p-4 rounded-2xl border-2 themed-input focus:ring-2 focus:ring-[#2D6CDF] dark:focus:ring-[#00E5FF] focus:outline-none font-sans text-sm tracking-widest transition duration-150" value="${appData.voice}" placeholder="Voice key..." />
                        <button onclick="document.getElementById('voice-input').value=''" class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                            <i data-lucide="x" class="w-5 h-5"></i>
                        </button>
                    </div>
                    
                    <button onclick="saveVoice()" class="w-full py-4 rounded-2xl font-bold btn-themed-primary transition active:scale-95 shadow-md flex items-center justify-center gap-2">
                        <i data-lucide="save" class="w-5 h-5"></i> UPDATE VOICE KEY
                    </button>
                </div>
            `;
        }

        function saveVoice() {
            const input = document.getElementById('voice-input');
            if (input) {
                appData.voice = input.value;
                saveLocalData();
                showToast("ElevenLabs key applied");
                setTimeout(navigateBack, 600);
            }
        }

        function renderWordsScreen(container) {
            container.innerHTML = `
                <div class="space-y-6 animate-fade-in">
                    <p class="text-sm font-medium themed-text-secondary">
                        Configure the triggers for beginning and concluding interactions.
                    </p>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider mb-2 themed-text-secondary">Wake-up Keyword</label>
                            <input id="start-word" type="text" class="w-full p-4 rounded-2xl border-2 themed-input focus:ring-2 focus:ring-[#2D6CDF] focus:outline-none font-bold text-lg" value="${appData.words.start}" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold uppercase tracking-wider mb-2 themed-text-secondary">Dismissal Keyword</label>
                            <input id="end-word" type="text" class="w-full p-4 rounded-2xl border-2 themed-input focus:ring-2 focus:ring-[#2D6CDF] focus:outline-none font-bold text-lg" value="${appData.words.end}" />
                        </div>
                    </div>
                    
                    <button onclick="saveWords()" class="w-full py-4 rounded-2xl font-bold btn-themed-primary transition active:scale-95 shadow-md flex items-center justify-center gap-2">
                        <i data-lucide="save" class="w-5 h-5"></i> APPLY KEYWORDS
                    </button>
                </div>
            `;
        }

        // Updates active triggers
        function saveWords() {
            const start = document.getElementById('start-word');
            const end = document.getElementById('end-word');
            if (start && end) {
                appData.words.start = start.value;
                appData.words.end = end.value;
                saveLocalData();
                showToast("Keyword triggers configured");
                setTimeout(navigateBack, 600);
            }
        }

        // --- Daily Events Screen (Fully cohesive theme-compliant palettes) ---
        function renderDailyScreen(container) {
            container.innerHTML = `
                <div class="space-y-4 animate-fade-in">
                    <p class="text-sm font-medium themed-text-secondary">
                        Configure events and alerts that run <strong>daily</strong> at a set hour.
                    </p>
                    <div class="border-2 themed-border rounded-2xl p-4 bg-gray-50/50 dark:bg-zinc-850/25 max-h-[220px] overflow-y-auto" id="daily-list">
                        <!-- Daily events injected dynamically -->
                    </div>
                    
                    <div class="border-t pt-3 border-gray-100 dark:border-zinc-800">
                        <p class="text-xs font-bold text-[#1E3A5F] dark:text-[#00E5FF] mb-2 uppercase tracking-wide">Add Daily Schedule</p>
                        <form id="daily-form" onsubmit="addDaily(event)" class="space-y-2">
                            <div class="grid grid-cols-3 gap-2">
                                <input type="time" id="daily-time" required class="col-span-1 p-2 text-xs border-2 themed-border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#2D6CDF] dark:focus:ring-[#00E5FF] bg-[#E9ECEF] dark:bg-zinc-800 text-gray-900 dark:text-white">
                                <input type="text" id="daily-message" placeholder="Task description..." required class="col-span-2 p-2 text-xs border-2 themed-border rounded-lg focus:outline-none focus:ring-2 focus:ring-[#2D6CDF] dark:focus:ring-[#00E5FF] bg-[#E9ECEF] dark:bg-zinc-900 text-gray-900 dark:text-white">
                            </div>
                            <button type="submit" class="w-full py-2.5 rounded-lg text-xs font-bold btn-themed-primary transition active:scale-95 flex items-center justify-center gap-1 shadow-md hover:scale-[1.01]">
                                <i data-lucide="plus" class="w-3.5 h-3.5"></i> Add Daily Alert
                            </button>
                        </form>
                    </div>
                </div>
            `;
            refreshDailyList();
        }

        function refreshDailyList() {
            const list = document.getElementById('daily-list');
            if (!list) return;
            
            if (appData.dailyEvents.length === 0) {
                list.innerHTML = `<p class="text-xs text-center text-gray-400 py-6 font-medium">No daily events found.</p>`;
                return;
            }

            let html = `
                <table class="w-full text-left text-xs border-collapse">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-zinc-700 pb-2 text-gray-400">
                            <th class="py-1 font-bold uppercase w-1/4">Time</th>
                            <th class="py-1 font-bold uppercase">Message</th>
                            <th class="py-1 text-right w-12"></th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            appData.dailyEvents.forEach((ev, idx) => {
                html += `
                    <tr class="border-b border-gray-100/55 dark:border-zinc-800/50 hover:bg-gray-100/50 dark:hover:bg-zinc-800/20">
                        <td class="py-2.5 font-extrabold text-[#2D6CDF] dark:text-[#00E5FF]">${ev.time}</td>
                        <td class="py-2.5 text-gray-600 dark:text-zinc-300 font-semibold">${ev.message}</td>
                        <td class="py-2.5 text-right">
                            <button onclick="removeDaily(${idx})" class="text-rose-500 hover:text-rose-700 hover:bg-rose-50 dark:hover:bg-rose-950/30 p-1 rounded transition">
                                <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });

            html += `</tbody></table>`;
            list.innerHTML = html;
            lucide.createIcons();
        }

        function addDaily(e) {
            e.preventDefault();
            const time = document.getElementById('daily-time').value;
            const msg = document.getElementById('daily-message').value.trim();
            if (time && msg) {
                appData.dailyEvents.push({ time, message: msg });
                appData.dailyEvents.sort((a, b) => a.time.localeCompare(b.time));
                saveLocalData();
                document.getElementById('daily-form').reset();
                refreshDailyList();
                showToast("Daily event added");
            }
        }

        function removeDaily(idx) {
            appData.dailyEvents.splice(idx, 1);
            saveLocalData();
            refreshDailyList();
            showToast("Daily event removed");
        }

        // --- Weekly Events (Using extra light grey backgrounds and high-contrast labels) ---
        function renderWeeklyScreen(container) {
            container.innerHTML = `
                <div class="space-y-4 animate-fade-in">
                    <p class="text-sm font-medium themed-text-secondary">
                        Configure weekly repeating occurrences. Click any weekday below to manage its specific schedules:
                    </p>
                    <div class="grid grid-cols-1 gap-2.5">
                        ${daysOfWeek.map(day => {
                            const eventCount = (appData.weeklyEvents[day] || []).length;
                            return `
                                <button onclick="openWeeklyEventsModal('${day}')" class="w-full flex justify-between items-center p-3.5 rounded-xl border-2 themed-border bg-gray-200/40 dark:bg-zinc-800/20 hover:bg-gray-200/70 dark:hover:bg-zinc-800/50 active:scale-95 transition">
                                    <span class="font-extrabold text-sm">${day}</span>
                                    <div class="flex items-center gap-2">
                                        ${eventCount > 0 ? `<span class="bg-amber-100 dark:bg-amber-950/40 text-amber-600 dark:text-amber-400 text-[10px] px-2 py-0.5 rounded-full font-bold">${eventCount} Scheduled</span>` : `<span class="text-[10px] text-slate-950 dark:text-zinc-500 font-black flex items-center gap-1">No events <i data-lucide="plus" class="w-3 h-3 text-slate-950 dark:text-zinc-500 stroke-[3px]"></i></span>`}
                                    </div>
                                </button>
                            `;
                        }).join('')}
                    </div>
                </div>
            `;
        }

        function openWeeklyEventsModal(day) {
            activeModalScope = { type: 'weekly', key: day };
            openEventsModal(`${day} (Weekly Repeats)`);
        }

        // --- Monthly Events Screen (Using extra light grey backgrounds and high-contrast labels) ---
        function renderMonthlyScreen(container) {
            let cells = '';
            for (let day = 1; day <= 31; day++) {
                const count = (appData.monthlyEvents[day] || []).length;
                cells += `
                    <button onclick="openMonthlyEventsModal(${day})" class="aspect-square rounded-xl border-2 themed-border flex flex-col justify-between p-1.5 transition hover:scale-105 active:scale-95 relative bg-gray-200/40 dark:bg-zinc-800/20 hover:bg-gray-200/70 dark:hover:bg-zinc-800/50">
                        <span class="font-extrabold text-sm">${day}</span>
                        ${count > 0 ? `<div class="w-2.5 h-2.5 bg-sky-500 rounded-full self-end shadow shadow-sky-500/50"></div>` : ''}
                    </button>
                `;
            }

            container.innerHTML = `
                <div class="space-y-4 animate-fade-in">
                    <p class="text-sm font-medium themed-text-secondary">
                        Configure events recurring on specific days of the month. Click a day number to schedule reminders:
                    </p>
                    <div class="grid grid-cols-7 gap-1.5 pt-2">
                        ${cells}
                    </div>
                </div>
            `;
        }

        function openMonthlyEventsModal(dayNum) {
            activeModalScope = { type: 'monthly', key: String(dayNum) };
            openEventsModal(`Day ${dayNum} of Month`);
        }

        // --- Standard Calendar Rendering (Single Time & Yearly Repeats) ---
        function renderCalendarScreen(container, viewType) {
            // Determine if leap year
            const isLeap = (currentYear % 4 === 0 && currentYear % 100 !== 0) || (currentYear % 400 === 0);
            months[1].days = isLeap ? 29 : 28;

            let firstDayDate = new Date(currentYear, currentMonth, 1);
            let jsDay = firstDayDate.getDay();
            let offset = jsDay === 0 ? 6 : jsDay - 1; // Align to Mon-Sun sequence

            let currentMonthName = months[currentMonth].name;
            let daysInMonth = months[currentMonth].days;

            // Yearly hides controls for year changing
            const yearPickerHTML = viewType === 'yearly' 
                ? `<div class="py-2 px-4 border border-dashed rounded-xl themed-border bg-gray-50/50 dark:bg-zinc-850/20 font-bold text-xs flex items-center gap-1.5 themed-text-secondary select-none">
                     <i data-lucide="lock" class="w-3.5 h-3.5"></i> Year Locked
                   </div>`
                : `<div class="relative w-1/2">
                        <button onclick="toggleYearDropdown()" class="w-full flex justify-between items-center py-2 px-3.5 rounded-xl border-2 themed-border font-bold text-sm bg-transparent">
                            <span>${currentYear}</span>
                            <i data-lucide="chevron-down" class="w-4 h-4"></i>
                        </button>
                        <div id="year-dropdown" class="absolute left-0 right-0 mt-1.5 bg-[#E9ECEF] dark:bg-zinc-900 border-2 themed-border rounded-xl shadow-xl max-h-48 overflow-y-auto hidden z-20">
                            ${Array.from({ length: 11 }, (_, i) => new Date().getFullYear() + i).map(y => `
                                <button onclick="selectYear(${y})" class="w-full text-left px-4 py-2 text-sm font-semibold hover:bg-gray-100 dark:hover:bg-zinc-800 transition">
                                    ${y}
                                </button>
                            `).join('')}
                        </div>
                    </div>`;

            let html = `
                <div class="space-y-4 animate-fade-in relative">
                    <!-- Dropdown Selectors Bar -->
                    <div class="flex justify-between items-center gap-2 select-none relative z-10">
                        <!-- Month Picker -->
                        <div class="relative ${viewType === 'yearly' ? 'w-1/2' : 'w-1/2'}">
                            <button onclick="toggleMonthDropdown()" class="w-full flex justify-between items-center py-2 px-3.5 rounded-xl border-2 themed-border font-bold text-sm bg-transparent">
                                <span>${currentMonthName}</span>
                                <i data-lucide="chevron-down" class="w-4 h-4"></i>
                            </button>
                            <div id="month-dropdown" class="absolute left-0 right-0 mt-1.5 bg-[#E9ECEF] dark:bg-zinc-900 border-2 themed-border rounded-xl shadow-xl max-h-48 overflow-y-auto hidden z-20">
                                ${months.map((m, idx) => `
                                    <button onclick="selectMonth(${idx})" class="w-full text-left px-4 py-2 text-sm font-semibold hover:bg-gray-100 dark:hover:bg-zinc-800 transition">
                                        ${m.name}
                                    </button>
                                `).join('')}
                            </div>
                        </div>

                        ${yearPickerHTML}
                    </div>

                    <!-- Weekdays Row -->
                    <div class="grid grid-cols-7 text-center font-bold text-xs themed-text-secondary uppercase tracking-wider py-1 select-none">
                        ${daysOfWeek.map(d => `<div class="p-1">${d}</div>`).join('')}
                    </div>

                    <!-- Calendar Grid -->
                    <div class="grid grid-cols-7 gap-1.5 relative">
            `;

            const today = new Date();
            const totalCells = 35;
            let dayCounter = 1;

            for (let i = 0; i < totalCells; i++) {
                if (i < offset || dayCounter > daysInMonth) {
                    html += `<div class="aspect-square bg-gray-50/20 rounded-xl border border-dashed border-gray-200 dark:border-zinc-800"></div>`;
                } else {
                    const thisDateStr = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(dayCounter).padStart(2, '0')}`;
                    const mmDdStr = `${String(currentMonth + 1).padStart(2, '0')}-${String(dayCounter).padStart(2, '0')}`;
                    
                    // Specific JS Date day indexing
                    const cellDateObj = new Date(currentYear, currentMonth, dayCounter);
                    const dayName = daysOfWeek[cellDateObj.getDay() === 0 ? 6 : cellDateObj.getDay() - 1];

                    // Recurrence Indicators Calculations
                    const hasSingle = (appData.events[thisDateStr] || []).length > 0;
                    const hasDaily = appData.dailyEvents.length > 0;
                    const hasWeekly = (appData.weeklyEvents[dayName] || []).length > 0;
                    const hasMonthly = (appData.monthlyEvents[String(dayCounter)] || []).length > 0;
                    const hasYearly = (appData.yearlyEvents[mmDdStr] || []).length > 0;

                    const isWeekend = (i % 7 === 5 || i % 7 === 6);
                    let cellBg = isWeekend ? 'bg-indigo-50/50 dark:bg-zinc-800/10' : 'bg-transparent';
                    
                    let isPast = false;
                    const checkPastObj = new Date(currentYear, currentMonth, dayCounter, 23, 59, 59);
                    if (checkPastObj < today && viewType === 'single_time') {
                        isPast = true;
                    }

                    let cellStyleClasses = "relative aspect-square rounded-xl border-2 flex flex-col justify-between p-1 cursor-pointer select-none transition hover:scale-105 active:scale-95 themed-border";
                    
                    // Thicker SINGLE Red diagonal line overlay that doesn't darken the background
                    let pastOverlay = isPast ? '<div class="absolute inset-0 rounded-[10px] pointer-events-none flex items-center justify-center"><div class="w-full border-t-[3.5px] border-red-500/95 transform -rotate-45"></div></div>' : '';

                    // Display list of mini-dots with specific recurrence keys
                    let dotsHTML = '<div class="flex gap-0.5 justify-end flex-wrap max-w-full overflow-hidden shrink-0">';
                    if (hasSingle)  dotsHTML += `<span class="w-1.5 h-1.5 bg-rose-500 rounded-full" title="Single Event"></span>`;
                    if (hasDaily)   dotsHTML += `<span class="w-1.5 h-1.5 bg-emerald-500 rounded-full" title="Daily event"></span>`;
                    if (hasWeekly)  dotsHTML += `<span class="w-1.5 h-1.5 bg-amber-500 rounded-full" title="Weekly event"></span>`;
                    if (hasMonthly) dotsHTML += `<span class="w-1.5 h-1.5 bg-sky-500 rounded-full" title="Monthly event"></span>`;
                    if (hasYearly)  dotsHTML += `<span class="w-1.5 h-1.5 bg-fuchsia-500 rounded-full" title="Yearly event"></span>`;
                    dotsHTML += '</div>';

                    html += `
                        <div onclick="handleCalendarDateClick('${viewType}', '${thisDateStr}', '${mmDdStr}', ${dayCounter})" class="${cellStyleClasses} ${cellBg}">
                            <span class="font-extrabold text-xs">${dayCounter}</span>
                            ${dotsHTML}
                            ${pastOverlay}
                        </div>
                    `;
                    dayCounter++;
                }
            }

            html += `
                    </div>
                    <!-- Calendar Legend of Recurrent Colors -->
                    <div class="pt-2 flex flex-wrap gap-x-3 gap-y-1.5 justify-center border-t border-dashed mt-3 py-2 text-[10px] font-bold">
                        <span class="flex items-center gap-1"><span class="w-2 h-2 bg-rose-500 rounded-full"></span> Single</span>
                        <span class="flex items-center gap-1"><span class="w-2 h-2 bg-emerald-500 rounded-full"></span> Daily</span>
                        <span class="flex items-center gap-1"><span class="w-2 h-2 bg-amber-500 rounded-full"></span> Weekly</span>
                        <span class="flex items-center gap-1"><span class="w-2 h-2 bg-sky-500 rounded-full"></span> Monthly</span>
                        <span class="flex items-center gap-1"><span class="w-2 h-2 bg-fuchsia-500 rounded-full"></span> Yearly</span>
                    </div>
                </div>
            `;
            container.innerHTML = html;
        }

        function handleCalendarDateClick(viewType, dateStr, mmDdStr, dayNum) {
            if (viewType === 'yearly') {
                activeModalScope = { type: 'yearly', key: mmDdStr };
                openEventsModal(`${dayNum} ${months[currentMonth].name} (Yearly Repeat)`);
            } else {
                activeModalScope = { type: 'single', key: dateStr };
                openEventsModal(`${dayNum} ${months[currentMonth].name} ${currentYear}`);
            }
        }

        // --- Shared Events Table Modal Operations ---
        function openEventsModal(titleText) {
            document.getElementById('modal-title').innerText = titleText;
            document.getElementById('modal-subtitle').innerText = `${activeModalScope.type} Schedule`;
            
            refreshModalEventsTable();

            const modal = document.getElementById('calendar-modal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => {
                const box = document.getElementById('modal-box');
                box.classList.remove('scale-95', 'opacity-0');
                box.classList.add('scale-100', 'opacity-100');
            }, 50);
        }

        // Fetches array of custom schedules
        function getActiveEventsList() {
            const type = activeModalScope.type;
            const key = activeModalScope.key;

            if (type === 'single') {
                return appData.events[key] || [];
            } else if (type === 'weekly') {
                return appData.weeklyEvents[key] || [];
            } else if (type === 'monthly') {
                return appData.monthlyEvents[key] || [];
            } else if (type === 'yearly') {
                return appData.yearlyEvents[key] || [];
            }
            return [];
        }

        function setActiveEventsList(list) {
            const type = activeModalScope.type;
            const key = activeModalScope.key;

            if (list.length === 0) {
                if (type === 'single') delete appData.events[key];
                else if (type === 'weekly') delete appData.weeklyEvents[key];
                else if (type === 'monthly') delete appData.monthlyEvents[key];
                else if (type === 'yearly') delete appData.yearlyEvents[key];
            } else {
                list.sort((a, b) => a.time.localeCompare(b.time));
                if (type === 'single') appData.events[key] = list;
                else if (type === 'weekly') appData.weeklyEvents[key] = list;
                else if (type === 'monthly') appData.monthlyEvents[key] = list;
                else if (type === 'yearly') appData.yearlyEvents[key] = list;
            }
            saveLocalData();
        }

        function refreshModalEventsTable() {
            const eventsList = getActiveEventsList();
            const container = document.getElementById('modal-events-list');

            if (eventsList.length === 0) {
                container.innerHTML = `
                    <div class="h-full flex flex-col items-center justify-center text-gray-400 py-8">
                        <i data-lucide="calendar-days" class="w-8 h-8 opacity-40 mb-1"></i>
                        <span class="text-xs font-semibold">No active event reminders</span>
                    </div>
                `;
                lucide.createIcons();
                return;
            }

            let html = `
                <table class="w-full text-left text-xs border-collapse font-sans">
                    <thead>
                        <tr class="border-b border-gray-100 dark:border-zinc-800 pb-2 text-gray-400">
                            <th class="py-1 font-bold uppercase w-16 text-gray-400">Time</th>
                            <th class="py-1 font-bold uppercase text-gray-400">Details</th>
                            <th class="py-1 text-right w-10"></th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            eventsList.forEach((ev, idx) => {
                html += `
                    <tr class="border-b border-gray-50 dark:border-zinc-800/40 hover:bg-gray-50/50 dark:hover:bg-zinc-800/10">
                        <td class="py-2.5 font-extrabold text-[#2D6CDF] dark:text-[#00E5FF]">${ev.time}</td>
                        <td class="py-2.5 text-gray-700 dark:text-gray-200 font-semibold tracking-wide">${ev.message}</td>
                        <td class="py-2.5 text-right">
                            <button onclick="deleteEventFromModal(${idx})" class="text-rose-500 hover:text-rose-700 hover:bg-rose-50 dark:hover:bg-rose-950/30 p-1 rounded transition">
                                <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });

            html += `</tbody></table>`;
            container.innerHTML = html;
            lucide.createIcons();
        }

        function handleFormSubmit(e) {
            e.preventDefault();
            const time = document.getElementById('event-time').value;
            const msg = document.getElementById('event-message').value.trim();

            if (time && msg) {
                const list = getActiveEventsList();
                list.push({ time, message: msg });
                setActiveEventsList(list);
                
                document.getElementById('new-event-form').reset();
                refreshModalEventsTable();
                showToast("Event saved successfully");
                
                // Refresh parent grid displays
                renderScreen();
            }
        }

        function deleteEventFromModal(idx) {
            const list = getActiveEventsList();
            list.splice(idx, 1);
            setActiveEventsList(list);
            refreshModalEventsTable();
            showToast("Event removed");
            renderScreen();
        }

        // Standard close method
        function closeModal() {
            const box = document.getElementById('modal-box');
            box.classList.remove('scale-100', 'opacity-100');
            box.classList.add('scale-95', 'opacity-0');
            setTimeout(() => {
                const modal = document.getElementById('calendar-modal');
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }, 150);
        }

        // --- Navigation Logic ---
        function navigate(dest) {
            currentPath.push(dest);
            renderScreen();
        }

        // Standard Back Action
        function navigateBack() {
            if (currentPath.length > 1) {
                currentPath.pop();
                renderScreen();
            }
        }

        function selectMonth(idx) {
            currentMonth = idx;
            showingMonthDropdown = false;
            renderScreen();
        }

        // Updates selected active year
        function selectYear(yr) {
            currentYear = yr;
            showingYearDropdown = false;
            renderScreen();
        }

        function toggleMonthDropdown() {
            const dropdown = document.getElementById('month-dropdown');
            showingMonthDropdown = !showingMonthDropdown;
            if (showingMonthDropdown) {
                dropdown.classList.remove('hidden');
                const yrDropdown = document.getElementById('year-dropdown');
                if (yrDropdown) yrDropdown.classList.add('hidden');
                showingYearDropdown = false;
            } else {
                dropdown.classList.add('hidden');
            }
        }

        // View configuration toggles
        function toggleYearDropdown() {
            const dropdown = document.getElementById('year-dropdown');
            showingYearDropdown = !showingYearDropdown;
            if (showingYearDropdown) {
                dropdown.classList.remove('hidden');
                document.getElementById('month-dropdown').classList.add('hidden');
                showingMonthDropdown = false;
            } else {
                dropdown.classList.add('hidden');
            }
        }
    </script>
</body>
</html>
